@page
@model PokerUIClient.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="flex items-center justify-center min-h-screen bg-gradient-to-br from-green-600 to-green-900 p-4">
    <div class="bg-white rounded-3xl shadow-2xl p-10 w-full max-w-md text-center">
        <h1 class="text-4xl font-extrabold text-green-900 mb-6">🎲 Poker Register</h1>

        @if (!Model.IsRegistered)
        {
            <form method="post" asp-page-handler="Register" class="flex flex-col gap-4">
                <input asp-for="PlayerName" placeholder="Nama Player" required
                       class="px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:outline-none text-gray-800" />
                <input asp-for="ChipStack" placeholder="Jumlah Chip" required
                       class="px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:outline-none text-gray-800" />
                <button type="submit"
                        class="mt-4 px-6 py-3 bg-gradient-to-r from-green-500 to-green-700 text-white font-bold rounded-xl shadow-lg hover:from-green-600 hover:to-green-800 transform hover:scale-105 transition">
                    Register
                </button>
            </form>
        }
        else
        {
            <p class="text-green-700 font-semibold mb-4">
                ✅ Player registered: <strong>@Model.PlayerName</strong> dengan @Model.ChipStack chips
            </p>

            <form method="post" asp-page-handler="StartGame">
                <button type="submit"
                        class="px-6 py-3 bg-gradient-to-r from-yellow-500 to-yellow-600 text-white font-bold rounded-xl shadow-lg hover:from-yellow-600 hover:to-yellow-700 transform hover:scale-105 transition">
                    Start Game
                </button>
            </form>
        }

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <p class="text-red-500 mt-4">@Model.ErrorMessage</p>
        }
    </div>
</div>
